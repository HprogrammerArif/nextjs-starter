{
  "name": "my-app",
  "author": "HprogrammerArif",
  "type": "module",
  "scripts": {
    "dev:next": "next dev",
    "dev": "run-p db-server:file dev:next",
    "build:next": "next build",
    "build-local": "run-p db-server:memory build:next --race",
    "build": "run-s db:migrate build:next",
    "start": "next start",
    "build-stats": "cross-env ANALYZE=true npm run build",
    "clean": "rimraf .next out coverage",
    "lint": "ultracite check --type-aware --type-check",
    "lint:fix": "ultracite fix --type-aware --type-check",
    "check:types": "tsc --noEmit --pretty",
    "check:deps": "knip",
    "check:i18n": "i18n-check -l src/locales -s en -u src -f next-intl",
    "commit": "commit",
    "test": "vitest run",
    "db-server:file": "pglite-server -p 5433 -m 100 --db=local.db --run=\"node node_modules/dotenv-cli/cli.js -c -- node node_modules/drizzle-kit/bin.cjs migrate\"",
    "db-server:memory": "pglite-server -p 5433 -m 100 --run=\"node node_modules/dotenv-cli/cli.js -c -- node node_modules/drizzle-kit/bin.cjs migrate\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "dotenv -c -- node scripts/db-migrate.js",
    "db:studio": "drizzle-kit studio",
    "storybook": "storybook dev -p 6006",
    "storybook:test": "vitest run --config .storybook/vitest.config.ts",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@sentry/nextjs": "^10.58.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "drizzle-orm": "^0.45.2",
    "next": "^16.2.9",
    "next-intl": "^4.13.0",
    "pg": "^8.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.79.0",
    "sharp": "^0.35.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@commitlint/prompt-cli": "^20.5.3",
    "@electric-sql/pglite-socket": "^0.2.4",
    "@lingual/i18n-check": "^0.9.5",
    "@next/bundle-analyzer": "^16.2.9",
    "@playwright/test": "^1.61.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/nextjs-vite": "^10.4.6",
    "@swc/helpers": "^0.5.23",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "knip": "^6.17.1",
    "lefthook": "^2.1.9",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0",
    "rimraf": "^6.1.3",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "ultracite": "^7.8.3",
    "vitest": "^4.1.5",
    "vitest-browser-react": "^2.2.0"
  },
  "engines": {
    "node": ">=20"
  },
  "postcss": {
    "plugins": {
      "@tailwindcss/postcss": {}
    }
  }
}
